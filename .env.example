# CallTelemetry Docker Compose Environment
# Copy to .env and customize for your deployment.
#
# Usage:
#   cp .env.example .env
#   # Edit values below, then:
#   docker compose up -d

# ─── Network ───
# Public IP address of this appliance (used for SIP/SRTP external media)
DEFAULT_IPV4=127.0.0.1

# ─── Image Versions ───
# Pin all service images here. OVA releases set these automatically.
WEB_VERSION=0.8.6-rc50
VUE_VERSION=0.8.6-rc49
TRACEROUTE_VERSION=1.0.2
JTAPI_VERSION=1.14.5
CT_MEDIA_VERSION=1.1.1
CT_SYSLOG_INGEST_VERSION=1.0.1

# ─── Database ───
# POSTGRES_USER=calltelemetry
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=calltelemetry_prod

# ─── Appliance Performance Profile ───
# Set via: ct appliance performance <small|medium|large>
# Also configurable during first-boot setup wizard (ct setup).
#
# Profiles set PG memory, connection limits, pool sizes, and Docker memory limits atomically.
# Changing profile requires a service restart: ct services restart
#
#   small  — 8GB RAM min,  up to 5,000 phones, 100 calls/sec
#            1GB shared_buffers, 32MB work_mem, DB limit 4g
#   medium — 16GB RAM min, up to 25,000 phones, 300 calls/sec
#            768MB shared_buffers, 16MB work_mem, DB limit 3g
#   large  — 32GB RAM min, 80,000+ phones, 600 calls/sec
#            2GB shared_buffers, 32MB work_mem, DB limit 6g
#
# PERFORMANCE_PROFILE=small

# ─── PostgreSQL Tuning ───
# PG_SHM_SIZE=4gb
# PG_SHARED_BUFFERS=1GB
# PG_EFFECTIVE_CACHE_SIZE=3GB
# PG_WORK_MEM=32MB
# PG_MAINTENANCE_WORK_MEM=128MB
# PG_PARALLEL_WORKERS=2
# PG_MAX_PARALLEL_WORKERS=4
# PG_AUTOVACUUM_WORKERS=4
# PG_AUTOVACUUM_VACUUM_SCALE=0.01
# PG_AUTOVACUUM_ANALYZE_SCALE=0.005
# PG_MAX_CONNECTIONS=200
#
# ─── Disk I/O Tuning ───
# Defaults are for spinning disk (10K RPM). For SSD/NVMe deployments, uncomment:
# PG_RANDOM_PAGE_COST=1.1
# PG_EFFECTIVE_IO_CONCURRENCY=200

# ─── Ecto Connection Pools ───
# DB_POOL_SIZE=50
# DB_BACKGROUND_POOL_SIZE=15
# DB_DISCOVERY_POOL_SIZE=25
# DB_OBAN_POOL_SIZE=20

# ─── Docker Memory Limits ───
# Safety net to prevent OOM kills. Set automatically by ct appliance performance.
# MUST exceed PG_SHARED_BUFFERS or postgres will be OOM-killed on startup.
# DB_MEM_LIMIT=4g
# WEB_MEM_LIMIT=3g
# TRACEROUTE_MEM_LIMIT=256m
# TRACEROUTE_CPU_LIMIT=0.5

# ─── Feature Profiles ───
# Comma-separated list of Docker Compose profiles to activate.
# Available profiles:
#   jtapi   - Phone control stack (jtapi-sidecar, ct-media) + SeaweedFS storage
#   otel    - Observability stack (Prometheus, Grafana, Loki, Tempo) + SeaweedFS storage
#   storage - SeaweedFS S3 storage only (auto-included by jtapi and otel)
#
# Examples:
#   COMPOSE_PROFILES=          # Base services only (no S3, no JTAPI, no otel)
#   COMPOSE_PROFILES=jtapi     # Base + JTAPI phone control + SeaweedFS
#   COMPOSE_PROFILES=jtapi,otel # Base + JTAPI + OpenTelemetry + SeaweedFS
#   COMPOSE_PROFILES=storage   # Base + SeaweedFS only (for S3 features without JTAPI)
COMPOSE_PROFILES=

# ─── JTAPI Configuration ───
# These are set automatically by `ct-cli jtapi enable` or `cli.sh jtapi enable`.
# Only needed when COMPOSE_PROFILES includes "jtapi".
# JTAPI_MODE=direct
# JTAPI_SIDECAR_ENDPOINT=jtapi-sidecar:50051
# JTAPI_SIDECAR_URL=http://jtapi-sidecar:8080
# S3 is auto-enabled when jtapi or otel profiles are active (SeaweedFS starts automatically).
# Only set to true manually if using COMPOSE_PROFILES=storage without jtapi.
S3_ENABLED=false
S3_ENDPOINT=http://seaweedfs:8333
CT_MEDIA_ENDPOINT=ct-media:50053

# ─── S3 / SeaweedFS Credentials ───
# Used by jtapi-sidecar, ct-media, and the web service for object storage.
# MUST match the credentials in seaweedfs-s3.json.
# Set BEFORE first start; changing after data exists requires reconfiguration.
S3_ACCESS_KEY_ID=changeme
S3_SECRET_ACCESS_KEY=changeme

# ─── Observability ───
# Grafana password — shared between web API (basic auth for dashboard push) and
# Grafana container (admin password). Generated by 'ct secrets generate'.
# REQUIRED — BootProvisioner will fail without this.
GRAFANA_PASSWORD=changeme

# OpenTelemetry (requires COMPOSE_PROFILES to include "otel")
# OTEL_ENABLED=false
# OTEL_SDK_DISABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
