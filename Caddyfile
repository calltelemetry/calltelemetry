# Caddyfile

{
    # Bind admin API to all interfaces so Prometheus can scrape :2019/metrics
    admin 0.0.0.0:2019
}

# HTTP: proxy CURRI/XCC/phone-portal paths to Phoenix, redirect everything else to HTTPS
:80 {
    @backend path /api/* /healthz /org/* /socket/* /live/*
    handle @backend {
        reverse_proxy web:4080
    }
    handle {
        redir https://{host}{uri} permanent
    }
}

:443 {
    # Expose Caddy metrics for Prometheus scraping (served on admin API :2019/metrics)
    metrics

    reverse_proxy /api* web:4000

    # Grafana SSO — Caddy validates CT JWT, passes user email to Grafana auth proxy
    @grafana path /grafana /grafana/*
    handle @grafana {
        forward_auth web:4000 {
            uri /api/internal/jwt-check
            copy_headers X-Webauth-User
        }
        reverse_proxy grafana:3000 {
            header_up X-Forwarded-Prefix /grafana
            header_up X-Forwarded-Host {http.request.host}
        }
    }

    # Prometheus — SSO via CT JWT
    @prometheus path /prometheus /prometheus/*
    handle @prometheus {
        forward_auth web:4000 {
            uri /api/internal/jwt-check
            copy_headers X-Webauth-User
        }
        uri strip_prefix /prometheus
        reverse_proxy prometheus:9090 {
            header_up X-Forwarded-Host {http.request.host}
        }
    }

    # AlertManager — SSO via CT JWT
    @alertmanager path /alertmanager /alertmanager/*
    handle @alertmanager {
        forward_auth web:4000 {
            uri /api/internal/jwt-check
            copy_headers X-Webauth-User
        }
        reverse_proxy alertmanager:9093 {
            header_up X-Forwarded-Host {http.request.host}
        }
    }

    # Tempo — trace visualization (queried via Grafana datasource)
    @tempo path /tempo /tempo/*
    handle @tempo {
        forward_auth web:4000 {
            uri /api/internal/jwt-check
            copy_headers X-Webauth-User
        }
        reverse_proxy tempo:3200 {
            header_up X-Forwarded-Host {http.request.host}
        }
    }

    reverse_proxy /* vue-web:80

    # Cache headers - order matters! More specific rules FIRST
    header /assets/* {
        Cache-Control "public, max-age=31536000, immutable"
        # Remove ETags for immutable assets - they're versioned in the filename
        -ETag
    }

    header /* {
        Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        # Remove ETags to prevent 304 responses with stale content
        -ETag
        # Add Pragma for HTTP/1.0 compatibility
        Pragma "no-cache"
    }

    tls /certs/appliance.crt /certs/appliance_key.pem  # Default certificate and key files
}